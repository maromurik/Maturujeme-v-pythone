import tkinter as tk
root = tk.Tk()
w = 512
h = 600
canvas = tk.Canvas(root,width=w,height=h,bg="white")
canvas.pack()
fr = open("ciernobiely_obrazok_1.txt","r",encoding = "utf-8")
velkosti = fr.readline().strip()
velkosti = velkosti.split()
sirka = int(velkosti[0])
vyska = int(velkosti[1])
vsetky_body = sirka*vyska
print(vsetky_body)

vysledok = {}
for riadok in fr:
    riadok = riadok.strip()
    for i in range(1,len(riadok),2):
        hodnota = int(riadok[i-1]+riadok[i],16)
        if hodnota in vysledok:
            vysledok[hodnota] +=1
        else:
            vysledok[hodnota] = 1

print(vysledok)
def histogram():
    mierka = max(vysledok.values())/ 500
    for key,val in vysledok.items():
        x = key*2
        y1 = 0
        y2 = val/mierka
        canvas.create_line(x,h,x,h-y2,width=2,fill = "grey")
    print(max(vysledok, key=vysledok.get))
histogram()

root.mainloop()
