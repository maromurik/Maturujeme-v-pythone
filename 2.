fr = open("hada.txt", "r", encoding="utf-8")
fw = open("abc.txt", "w", encoding="utf-8")
poc = 0
najdlhsia = 0

for riadok in fr:
    poc += 1
    hra = riadok.strip()
    if len(hra) > najdlhsia:
        najdlhsia = len(hra)
    poc2 = 1
    for i in range(1, len(hra)):
        if hra[i] == hra[i-1]:
            poc2 += 1
        else:
            fw.write(hra[i-1] + str(poc2) + " ")
            poc2 = 1
    if len(hra) > 0:
        fw.write(hra[-1] + str(poc2))
    fw.write("\n")

print(f"Pocet hier: {poc}")
print(f"Najdlhsia hra: {najdlhsia} tahov")
